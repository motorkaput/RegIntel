# Kubernetes Secrets Template
# DO NOT commit this file with real values
# Create the actual secret file by copying this template:
# cp secret.yaml.sample secret.yaml
# Then edit secret.yaml with real base64-encoded values

apiVersion: v1
kind: Secret
metadata:
  name: permeate-secrets
type: Opaque
data:
  # Base64 encoded values - use: echo -n "your-value" | base64
  database-url: <BASE64_ENCODED_DATABASE_URL>
  jwt-secret: <BASE64_ENCODED_JWT_SECRET>
  session-secret: <BASE64_ENCODED_SESSION_SECRET>
  bootstrap-token: <BASE64_ENCODED_BOOTSTRAP_TOKEN>
  postmark-token: <BASE64_ENCODED_POSTMARK_TOKEN>
  razorpay-key-id: <BASE64_ENCODED_RAZORPAY_KEY_ID>
  razorpay-key-secret: <BASE64_ENCODED_RAZORPAY_KEY_SECRET>
  billing-webhook-secret: <BASE64_ENCODED_WEBHOOK_SECRET>
  openai-api-key: <BASE64_ENCODED_OPENAI_API_KEY>
  s3-access-key: <BASE64_ENCODED_S3_ACCESS_KEY>
  s3-secret-key: <BASE64_ENCODED_S3_SECRET_KEY>

---
# Example commands to create secrets:
# kubectl create secret generic permeate-secrets \
#   --from-literal=database-url="postgresql://user:pass@host:5432/db" \
#   --from-literal=jwt-secret="your-jwt-secret" \
#   --from-literal=session-secret="your-session-secret" \
#   --from-literal=bootstrap-token="your-bootstrap-token" \
#   --from-literal=postmark-token="your-postmark-token" \
#   --from-literal=razorpay-key-id="your-razorpay-key" \
#   --from-literal=razorpay-key-secret="your-razorpay-secret" \
#   --from-literal=billing-webhook-secret="your-webhook-secret" \
#   --from-literal=openai-api-key="your-openai-key" \
#   --from-literal=s3-access-key="your-s3-access-key" \
#   --from-literal=s3-secret-key="your-s3-secret-key"