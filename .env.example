# PerMeaTe Enterprise Environment Configuration
# Copy this file to .env.local and fill in your values

# Application Configuration
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/permeate

# Authentication & Security
JWT_SECRET=your-super-secure-jwt-secret-key-at-least-32-chars
SESSION_SECRET=your-super-secure-session-secret-key-at-least-32-chars
BOOTSTRAP_TOKEN=your-bootstrap-token-for-initial-tenant-creation

# Email Configuration
# For development: console | For production: postmark
DEV_EMAIL_MODE=console
POSTMARK_API_TOKEN=your-postmark-api-token
EMAIL_FROM=noreply@yourdomain.com

# Payment Processing (Razorpay)
PAYMENT_PROVIDER=mock
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
BILLING_WEBHOOK_SECRET=your-webhook-secret-for-razorpay

# File Storage
# For development: local | For production: s3
DEV_STORAGE_MODE=local
UPLOAD_DIR=./uploads
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=your-s3-bucket-name
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key

# AI Services
OPENAI_API_KEY=your-openai-api-key

# Rate Limiting & Performance
RATE_LIMIT_QPH_DEFAULT=1000
REDIS_URL=redis://localhost:6379

# Data Retention & Compliance
DATA_RETENTION_DAYS_DEFAULT=365

# Logging & Monitoring
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Development Features
DEMO_MODE=false

# Database Connection Details (for Docker Compose)
POSTGRES_DB=permeate
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# MailHog Configuration (Development)
MAILHOG_SMTP_PORT=1025
MAILHOG_WEB_PORT=8025

# Next.js Configuration
NEXT_TELEMETRY_DISABLED=1