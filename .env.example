# Database (required)
DATABASE_URL=postgresql://user:password@host:5432/regintel

# OpenAI (required for AI features)
OPENAI_API_KEY=sk-...

# Mistral (optional, for OCR fallback)
MISTRAL_API_KEY=

# Session (required in production)
SESSION_SECRET=generate-a-secure-random-string

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://regintel.darkstreet.tech/api/auth/google/callback

# Microsoft OAuth (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=https://regintel.darkstreet.tech/api/auth/microsoft/callback

# Razorpay (optional, for payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SendGrid (optional, for emails)
SENDGRID_API_KEY=

# App URL (used for OAuth callbacks)
APP_URL=https://regintel.darkstreet.tech

# Admin (optional, for initial admin setup)
ADMIN_EMAIL=david@darkstreet.org
ADMIN_PASSWORD=

# Server
PORT=5000
NODE_ENV=production
