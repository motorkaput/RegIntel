// PerMeaTe Enterprise - Prisma Schema
// Multi-tenant B2B SaaS with PostgreSQL and Row Level Security (RLS)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  admin
  org_leader
  functional_leader
  project_lead
  team_member
}

enum GoalStatus {
  draft
  active
  completed
  cancelled
}

enum ProjectStatus {
  planning
  active
  on_hold
  completed
  cancelled
}

enum TaskStatus {
  todo
  in_progress
  review
  done
  blocked
}

enum Priority {
  low
  medium
  high
  critical
}

enum BillingProvider {
  razorpay
  stripe
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  trialing
  incomplete
}

enum ExternalSystem {
  jira
  trello
  asana
}

enum UsageKind {
  ai_tokens
  active_seat
  task_evaluated
}

enum ScoreType {
  self
  review
  final
}

enum AssignmentRole {
  owner
  contributor
  reviewer
}

// Core Models

model Tenant {
  id                String   @id @default(uuid())
  name              String
  domain            String   @unique
  subscription_tier String   @default("starter")
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  // Relations
  users             User[]
  goals             Goal[]
  projects          Project[]
  tasks             Task[]
  subscriptions     BillingSubscription[]
  tenant_settings   TenantSettings?
  skills            Skill[]
  user_skills       UserSkill[]
  assignments       Assignment[]
  effort_estimates  EffortEstimate[]
  work_items        WorkItem[]
  scores            Score[]
  score_iterations  ScoreIteration[]
  audit_logs        AuditLog[]
  usage_events      UsageEvent[]
  invitations       Invitation[]

  @@map("tenants")
}

model User {
  id                  String    @id @default(uuid())
  tenant_id           String
  email               String
  password_hash       String?
  role                UserRole
  first_name          String
  last_name           String
  avatar_url          String?
  email_verified      Boolean   @default(false)
  magic_link_token    String?
  magic_link_expires  DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  // Relations
  tenant              Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  owned_goals         Goal[]          @relation("GoalOwner")
  led_projects        Project[]       @relation("ProjectLead")
  assigned_tasks      Task[]          @relation("TaskAssignee")
  user_skills         UserSkill[]
  assignments         Assignment[]
  scores              Score[]
  score_iterations    ScoreIteration[] @relation("ScoreActor")
  audit_logs          AuditLog[]      @relation("AuditActor")

  @@unique([tenant_id, email])
  @@map("users")
}

model Goal {
  id            String     @id @default(uuid())
  tenant_id     String
  title         String
  description   String?
  owner_id      String
  status        GoalStatus @default(draft)
  priority      Priority   @default(medium)
  target_date   DateTime?
  ai_breakdown  Json?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  // Relations
  tenant        Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  owner         User       @relation("GoalOwner", fields: [owner_id], references: [id])
  projects      Project[]

  @@index([tenant_id, status])
  @@map("goals")
}

model Project {
  id               String        @id @default(uuid())
  tenant_id        String
  goal_id          String
  title            String
  description      String?
  project_lead_id  String
  status           ProjectStatus @default(planning)
  priority         Priority      @default(medium)
  start_date       DateTime?
  end_date         DateTime?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  // Relations
  tenant           Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  goal             Goal          @relation(fields: [goal_id], references: [id], onDelete: Cascade)
  project_lead     User          @relation("ProjectLead", fields: [project_lead_id], references: [id])
  tasks            Task[]
  work_items       WorkItem[]

  @@index([tenant_id, status])
  @@map("projects")
}

model Task {
  id               String    @id @default(uuid())
  tenant_id        String
  project_id       String
  title            String
  description      String?
  assignee_id      String?
  status           TaskStatus @default(todo)
  priority         Priority   @default(medium)
  estimated_hours  Decimal?   @db.Decimal(6,2)
  due_date         DateTime?
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt

  // Relations
  tenant           Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  project          Project          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  assignee         User?            @relation("TaskAssignee", fields: [assignee_id], references: [id])
  assignments      Assignment[]
  effort_estimates EffortEstimate[]
  work_items       WorkItem[]
  scores           Score[]
  score_iterations ScoreIteration[]

  @@index([tenant_id, status])
  @@map("tasks")
}

model BillingSubscription {
  id                    String             @id @default(uuid())
  tenant_id             String
  provider              BillingProvider
  external_id           String
  plan_id               String
  status                SubscriptionStatus
  current_period_start  DateTime?
  current_period_end    DateTime?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt

  // Relations
  tenant                Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("billing_subscriptions")
}

model TenantSettings {
  id                   String          @id @default(uuid())
  tenant_id            String          @unique
  payment_provider     BillingProvider @default(razorpay)
  razorpay_key_id      String?
  razorpay_key_secret  String?
  email_from           String?
  data_retention_days  Int?
  rate_limit_qph       Int?
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  // Relations
  tenant               Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Skill {
  id          String      @id @default(uuid())
  tenant_id   String
  name        String
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  // Relations
  tenant      Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user_skills UserSkill[]

  @@map("skills")
}

model UserSkill {
  id         String   @id @default(uuid())
  tenant_id  String
  user_id    String
  skill_id   String
  level      Int      // 1-5 skill level
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  skill      Skill    @relation(fields: [skill_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, user_id, skill_id])
  @@map("user_skills")
}

model Assignment {
  id         String         @id @default(uuid())
  tenant_id  String
  task_id    String
  user_id    String
  role       AssignmentRole
  created_at DateTime       @default(now())

  // Relations
  tenant     Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  task       Task           @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, task_id, user_id, role])
  @@map("assignments")
}

model EffortEstimate {
  id         String   @id @default(uuid())
  tenant_id  String
  task_id    String
  hours      Decimal  @db.Decimal(6,2)
  basis      String?
  created_at DateTime @default(now())

  // Relations
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@map("effort_estimates")
}

model WorkItem {
  id              String         @id @default(uuid())
  tenant_id       String
  external_system ExternalSystem
  external_id     String
  project_id      String?
  task_id         String?
  payload         Json
  status          String
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  // Relations
  tenant          Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  project         Project?       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  task            Task?          @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, external_system, external_id])
  @@map("work_items")
}

model Score {
  id         String    @id @default(uuid())
  tenant_id  String
  task_id    String
  user_id    String
  value      Int       // 1-5
  type       ScoreType
  rationale  String?
  created_at DateTime  @default(now())

  // Relations
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  task       Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("scores")
}

model ScoreIteration {
  id             String   @id @default(uuid())
  tenant_id      String
  task_id        String
  actor_user_id  String
  from_value     Int?
  to_value       Int
  reason         String?
  created_at     DateTime @default(now())

  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  task           Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  actor_user     User     @relation("ScoreActor", fields: [actor_user_id], references: [id], onDelete: Cascade)

  @@map("score_iterations")
}

model AuditLog {
  id            String   @id @default(uuid())
  tenant_id     String
  actor_user_id String?
  entity_type   String
  entity_id     String
  action        String
  before        Json?
  after         Json?
  created_at    DateTime @default(now())

  // Relations
  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  actor_user    User?    @relation("AuditActor", fields: [actor_user_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
  @@map("audit_logs")
}

model UsageEvent {
  id          String    @id @default(uuid())
  tenant_id   String
  kind        UsageKind
  amount      Int
  occurred_at DateTime  @db.Timestamptz
  metadata    Json?

  // Relations
  tenant      Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, occurred_at])
  @@map("usage_events")
}

model Invitation {
  id          String    @id @default(uuid())
  tenant_id   String
  email       String
  role        UserRole
  token       String
  expires_at  DateTime
  accepted_at DateTime?
  created_at  DateTime  @default(now())

  // Relations
  tenant      Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, email])
  @@map("invitations")
}