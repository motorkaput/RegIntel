# Test Environment Configuration
NODE_ENV=test
APP_URL=http://localhost:3000

# Test Database (ephemeral)
DATABASE_URL=postgresql://test:test@localhost:5432/permeate_test

# Email Configuration for Testing
DEV_EMAIL_MODE=console

# Auth Configuration
JWT_SECRET=test-jwt-secret-key-for-e2e-testing
SESSION_SECRET=test-session-secret-for-e2e-testing

# Bootstrap Token for Testing
BOOTSTRAP_TOKEN=test-bootstrap-token-123

# Billing Configuration (Mock Mode)
PAYMENT_PROVIDER=mock
BILLING_WEBHOOK_SECRET=test-webhook-secret

# Rate Limiting
DEFAULT_RATE_LIMIT_QPH=1000

# AI Configuration (Mock)
OPENAI_API_KEY=test-key-not-real

# File Storage
DEV_STORAGE_MODE=local
UPLOAD_DIR=./test-uploads

# Logging
LOG_LEVEL=error