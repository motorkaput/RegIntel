# Production Environment Configuration
# Rename to .env.production.local and fill with production values

# Application
APP_URL=https://yourdomain.com
NODE_ENV=production
PORT=3000

# Database (Production PostgreSQL)
DATABASE_URL=postgresql://username:password@hostname:5432/permeate_prod

# Security (Generate secure secrets)
JWT_SECRET=CHANGE_ME_TO_SECURE_RANDOM_STRING_32_CHARS_MIN
SESSION_SECRET=CHANGE_ME_TO_SECURE_RANDOM_STRING_32_CHARS_MIN
BOOTSTRAP_TOKEN=CHANGE_ME_TO_SECURE_BOOTSTRAP_TOKEN

# Email (Production - Use Postmark)
DEV_EMAIL_MODE=postmark
POSTMARK_API_TOKEN=YOUR_PRODUCTION_POSTMARK_TOKEN
EMAIL_FROM=noreply@yourdomain.com

# Payment Processing (Production Razorpay)
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=YOUR_PRODUCTION_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_PRODUCTION_RAZORPAY_SECRET
BILLING_WEBHOOK_SECRET=YOUR_SECURE_WEBHOOK_SECRET

# File Storage (Production - Use S3)
DEV_STORAGE_MODE=s3
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=your-production-bucket
S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY
S3_SECRET_KEY=YOUR_S3_SECRET_KEY

# AI Services (Production)
OPENAI_API_KEY=YOUR_PRODUCTION_OPENAI_KEY

# Performance & Scaling
RATE_LIMIT_QPH_DEFAULT=5000
REDIS_URL=redis://your-redis-host:6379

# Compliance
DATA_RETENTION_DAYS_DEFAULT=365

# Monitoring (Production)
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-collector:4318

# Security Headers
NEXT_TELEMETRY_DISABLED=1

# Production Database Details
DATABASE_HOST=your-db-host
DATABASE_PORT=5432

# Disable Demo Features
DEMO_MODE=false